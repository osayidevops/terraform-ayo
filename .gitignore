# -------------------------
# Terraform working directory
# -------------------------
.terraform/

# -------------------------
# State files (NEVER commit)
# -------------------------
*.tfstate
*.tfstate.backup
*.tfstate.*

# -------------------------
# Crash logs
# -------------------------
crash.log
crash.*.log

# -------------------------
# Sensitive variables
# -------------------------
*.tfvars
*.tfvars.json

# -------------------------
# Override files (local-only overrides)
# -------------------------
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -------------------------
# Terraform config files
# -------------------------
.terraformrc
terraform.rc

# -------------------------
# Terraform plan files
# -------------------------
*.tfplan

# -------------------------
# Ansible
# -------------------------
*.retry
ansible/.ansible_async/
